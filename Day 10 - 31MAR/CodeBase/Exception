public class Exception {
    public static void main(String[] args) {
        try{
            int a=10/0;
            System.out.println(a);
        }catch(ArithmeticException e){
            System.out.println(e);
        }
        try{
            int[] a={1,2,3,4};
            System.out.println(a[5]);
        }catch(ArrayIndexOutOfBoundsException e){
            System.out.println(e);
        }
    }
}
