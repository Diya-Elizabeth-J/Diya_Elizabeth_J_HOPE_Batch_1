class A {
    public void showA() {
        System.out.println("Public Method in A");
    }

    protected void showB() {
        System.out.println("Protected Method in A");
    }

    void showC() {
        System.out.println("Default Method in A");
    }

    private void showD() {
        System.out.println("Private Method in A");
    }

    public void accessPrivate() {
        showD(); 
    }
}

class B extends A {
    public void displayB() {
        System.out.println("\nClass B:");
        showA();
        showB();
        showC();
    }
}

class C extends B {
    public void displayC() {
        System.out.println("\nClass C:");
        showA();
        showB();
    }
}
class D extends C {
    public void displayD() {
        System.out.println("\nClass D:");
        showA();
    }
}

public class Task1 {
    public static void main(String[] args) {
        D obj = new D();

        obj.showA();
        obj.accessPrivate(); 
        obj.displayB();
        obj.displayC();
        obj.displayD();
    }
}
