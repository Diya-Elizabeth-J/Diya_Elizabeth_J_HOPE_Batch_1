class Solution {
    public int maximumWealth(int[][] accounts) {
        int max=Integer.MIN_VALUE;
        int r=accounts.length,c=accounts[0].length;
        for(int i=0;i<r;i++){
            int rowValue=0;
            for(int j=0;j<c;j++){
                rowValue+=accounts[i][j];
            }
            if(rowValue>=max)
                max=rowValue;
        }
        return max;
    }
}
